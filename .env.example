# =============================================================================
# Planthor — Local Development Environment Variables
# =============================================================================
# Copy this file to .env and fill in values appropriate for your machine.
#   cp .env.example .env
#
# NEVER commit the .env file to source control.
#
# NOTE: Variable references like ${VAR} below are for documentation purposes
# only. Docker Compose expands them automatically from the same .env file at
# runtime, but many other tools (shells, CI systems) may not. Replace any
# ${…} references with literal values if your tooling requires it.
# =============================================================================

# -----------------------------------------------------------------------------
# General
# -----------------------------------------------------------------------------
COMPOSE_PROJECT_NAME=planthor
APP_ENV=local
APP_DEBUG=true
APP_LOG_LEVEL=debug

# -----------------------------------------------------------------------------
# PostgreSQL
# -----------------------------------------------------------------------------
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=planthor_dev
POSTGRES_USER=planthor
POSTGRES_PASSWORD=changeme_local

# Convenience DSN used by most frameworks/ORMs
DATABASE_URL=postgresql://${POSTGRES_USER}:${POSTGRES_PASSWORD}@${POSTGRES_HOST}:${POSTGRES_PORT}/${POSTGRES_DB}

# -----------------------------------------------------------------------------
# Redis
# -----------------------------------------------------------------------------
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_URL=redis://${REDIS_HOST}:${REDIS_PORT}

# -----------------------------------------------------------------------------
# API Service
# -----------------------------------------------------------------------------
API_PORT=8000
API_SECRET_KEY=super_secret_change_me_in_production

# -----------------------------------------------------------------------------
# Frontend / Web Service
# -----------------------------------------------------------------------------
WEB_PORT=3000
NEXT_PUBLIC_API_URL=http://localhost:8000

# -----------------------------------------------------------------------------
# MailHog (local SMTP / email testing)
# -----------------------------------------------------------------------------
MAIL_HOST=mailhog
MAIL_PORT=1025
MAIL_FROM=no-reply@planthor.local

# MailHog web UI is accessible at http://localhost:8025
MAILHOG_UI_PORT=8025

# =============================================================================
# Planthor — Local Development Environment Variables
# =============================================================================
# Copy this file to .env and fill in values appropriate for your machine.
#   cp .env.example .env
#
# NEVER commit the .env file to source control.
#
# NOTE: Variable references like ${VAR} below are for documentation purposes
# only. Docker Compose expands them automatically from the same .env file at
# runtime, but many other tools (shells, CI systems) may not. Replace any
# ${…} references with literal values if your tooling requires it.
# =============================================================================

# -----------------------------------------------------------------------------
# General
# -----------------------------------------------------------------------------
COMPOSE_PROJECT_NAME=planthor

# -----------------------------------------------------------------------------
# PostgreSQL (used by Keycloak)
# -----------------------------------------------------------------------------
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=keycloak
POSTGRES_USER=keycloak
POSTGRES_PASSWORD=keycloak_local

# -----------------------------------------------------------------------------
# Keycloak — identity and access management
#   Admin console: http://localhost:8080
#   Realm:         planthor  (auto-imported from keycloak/realm-export.json)
#
# WARNING: All credentials below are for LOCAL DEVELOPMENT ONLY.
#          Never reuse them in staging or production environments.
# -----------------------------------------------------------------------------
KEYCLOAK_VERSION=26.0
KEYCLOAK_PORT=8080
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=admin

# Keycloak OIDC endpoints (for reference — used in app configuration):
#   Authorization: http://localhost:8080/realms/planthor/protocol/openid-connect/auth
#   Token:         http://localhost:8080/realms/planthor/protocol/openid-connect/token
#   JWKS:          http://localhost:8080/realms/planthor/protocol/openid-connect/certs

# -----------------------------------------------------------------------------
# PlanthorWebApp — pulled from GitHub Container Registry (GHCR)
#
# UPDATE THIS VALUE when the image name or tag changes in PlanthorWebApp.
# The image is published by the PlanthorWebApp CI workflow to:
#   ghcr.io/planthor/planthorwebapp   (tag: main  or  <semver>)
# -----------------------------------------------------------------------------
WEBAPP_IMAGE=ghcr.io/planthor/planthorwebapp:main
WEBAPP_PORT=3000
BASE_URL=http://localhost:3000

